# Docker Compose environment variables
# Copy to .env and adjust values for your environment

# --- Database ---
POSTGRES_PASSWORD=agendity_dev

# --- NATS (must match in agendity-api/.env and agendity-web/.env.local) ---
NATS_AUTH_TOKEN=dev_nats_token

# --- Rails secrets (generate real values for production) ---
SECRET_KEY_BASE=dev-secret-key-base-change-in-production-must-be-at-least-128-bits-long-for-security
DEVISE_JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production

# --- Active Record Encryption ---
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=dev-primary-key-change-in-prod-32ch
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=dev-deterministic-key-change-32ch
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=dev-salt-change-in-production-32c

# --- Pexels API (free stock photos for cover gallery) ---
# Get your free API key at https://www.pexels.com/api/
PEXELS_API_KEY=
