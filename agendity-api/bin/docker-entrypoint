#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the web server (puma or rails server), prepare the database.
# The CMD in Dockerfile uses "bundle exec puma", not "bin/rails server".
if echo "$@" | grep -qE '(puma|rails server|rails s)'; then
  ./bin/rails db:prepare
fi

exec "${@}"
