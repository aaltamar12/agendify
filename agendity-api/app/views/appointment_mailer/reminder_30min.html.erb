<h2>¡Tu cita es en 30 minutos!</h2>

<p>¡Hola, <%= @customer.name %>! Te recordamos que tu cita en <strong><%= @business.name %></strong> es en 30 minutos.</p>

<table class="detail-table">
  <tr>
    <td>Servicio</td>
    <td><%= @service.name %></td>
  </tr>
  <tr>
    <td>Profesional</td>
    <td><%= @employee.name %></td>
  </tr>
  <tr>
    <td>Hora</td>
    <td><%= @appointment.start_time.strftime("%I:%M %p") %></td>
  </tr>
  <tr>
    <td>Lugar</td>
    <td><%= @business.name %><%= " — #{@business.address}" if @business.address.present? %></td>
  </tr>
</table>

<% if @appointment.ticket_code.present? %>
  <p><strong>Tu código de ticket:</strong></p>
  <div class="ticket-code"><%= @appointment.ticket_code %></div>
<% end %>

<p>¡Te esperamos!</p>
