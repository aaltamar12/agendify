<h2>Recibo de pago</h2>

<p>Hola, <strong><%= @employee.name %></strong>.</p>

<p>Este es tu recibo de pago correspondiente al cierre de caja del <strong><%= @date.strftime("%d/%m/%Y") %></strong> en <strong><%= @business.name %></strong>.</p>

<table class="detail-table">
  <tr>
    <td>Empleado</td>
    <td><%= @employee.name %></td>
  </tr>
  <tr>
    <td>Fecha</td>
    <td><%= @date.strftime("%d/%m/%Y") %></td>
  </tr>
  <tr>
    <td>Citas atendidas</td>
    <td><%= @employee_payment.appointments_count %></td>
  </tr>
  <tr>
    <td>Total generado</td>
    <td>$<%= number_with_delimiter(@employee_payment.total_earned.to_i) %></td>
  </tr>
  <tr>
    <td>Comisi&oacute;n (<%= @employee_payment.commission_pct %>%)</td>
    <td>$<%= number_with_delimiter(@employee_payment.commission_amount.to_i) %></td>
  </tr>
  <% if @employee_payment.pending_from_previous.to_d > 0 %>
    <tr>
      <td>Saldo pendiente anterior</td>
      <td>$<%= number_with_delimiter(@employee_payment.pending_from_previous.to_i) %></td>
    </tr>
  <% end %>
  <tr>
    <td>Total a pagar</td>
    <td><strong>$<%= number_with_delimiter(@employee_payment.total_owed.to_i) %></strong></td>
  </tr>
  <tr>
    <td>Monto pagado</td>
    <td><strong>$<%= number_with_delimiter(@employee_payment.amount_paid.to_i) %></strong></td>
  </tr>
  <tr>
    <td>M&eacute;todo de pago</td>
    <td><%= @employee_payment.cash? ? "Efectivo" : "Transferencia" %></td>
  </tr>
</table>

<% remaining = @employee_payment.remaining_debt %>
<% if remaining > 0 %>
  <p style="color: #e53e3e; font-weight: 600;">
    Saldo pendiente: $<%= number_with_delimiter(remaining.to_i) %>
  </p>
<% else %>
  <p style="color: #38a169; font-weight: 600;">
    Pago completo &mdash; sin saldo pendiente.
  </p>
<% end %>

<% if @employee_payment.notes.present? %>
  <p><strong>Notas:</strong> <%= @employee_payment.notes %></p>
<% end %>

<p style="color: #888888; font-size: 14px; margin-top: 24px;">
  Este recibo fue generado autom&aacute;ticamente por Agendity al momento del cierre de caja.
</p>
