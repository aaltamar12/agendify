<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      color: #333333;
      line-height: 1.6;
      font-size: 14px;
    }
    .receipt-container {
      max-width: 600px;
      margin: 0 auto;
    }
    .receipt-header {
      background-color: #7c3aed;
      padding: 20px 24px;
      text-align: center;
      border-radius: 8px 8px 0 0;
    }
    .receipt-header h1 {
      margin: 0;
      color: #ffffff;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 1px;
    }
    .receipt-body {
      padding: 24px;
      border: 1px solid #e2e8f0;
      border-top: none;
    }
    .receipt-body h2 {
      margin-top: 0;
      color: #1a1a2e;
      font-size: 18px;
    }
    .receipt-body p {
      margin: 6px 0;
      color: #555555;
    }
    .detail-table {
      width: 100%;
      border-collapse: collapse;
      margin: 16px 0;
    }
    .detail-table td {
      padding: 8px 4px;
      border-bottom: 1px solid #eeeeee;
    }
    .detail-table td:first-child {
      font-weight: 600;
      color: #333333;
      width: 45%;
    }
    .detail-table td:last-child {
      color: #555555;
      text-align: right;
    }
    .total-row td {
      font-weight: 700;
      font-size: 15px;
      border-top: 2px solid #7c3aed;
      border-bottom: 2px solid #7c3aed;
    }
    .status-paid {
      color: #38a169;
      font-weight: 600;
    }
    .status-pending {
      color: #e53e3e;
      font-weight: 600;
    }
    .receipt-footer {
      padding: 16px 24px;
      text-align: center;
      background-color: #f9fafb;
      border: 1px solid #e2e8f0;
      border-top: none;
      border-radius: 0 0 8px 8px;
    }
    .receipt-footer p {
      margin: 0;
      font-size: 11px;
      color: #999999;
    }
  </style>
</head>
<body>
  <div class="receipt-container">
    <div class="receipt-header">
      <h1>Agendity</h1>
    </div>
    <div class="receipt-body">
      <%= yield %>
    </div>
    <div class="receipt-footer">
      <p>Powered by Agendity &mdash; La plataforma de gesti&oacute;n para tu negocio</p>
    </div>
  </div>
</body>
</html>
